
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Core user entity for customers, sellers, and admins.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "seller", "admin"] },
        "status": { "type": "string", "enum": ["active", "banned"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role", "createdAt"]
    },
    "SellerProfile": {
      "title": "SellerProfile",
      "type": "object",
      "description": "Business details for vendors.",
      "properties": {
        "userId": { "type": "string" },
        "businessName": { "type": "string" },
        "phone": { "type": "string" },
        "country": { "type": "string" },
        "bankName": { "type": "string" },
        "accountNumber": { "type": "string" },
        "accountName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "businessName", "status", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sellerId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "imageUrls": { "type": "array", "items": { "type": "string" } },
        "stock": { "type": "number" },
        "averageRating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "isFeatured": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["sellerId", "title", "price", "stock", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "customerEmail": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "paymentStatus": { "type": "string", "enum": ["pending", "paid", "failed"] },
        "deliveryStatus": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "shippingAddress": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "totalAmount", "paymentStatus", "deliveryStatus", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "rating", "comment", "createdAt"]
    },
    "Category": {
      "title": "Category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "imageUrl": { "type": "string" },
        "count": { "type": "string" }
      }
    },
    "Testimonial": {
      "title": "Testimonial",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "city": { "type": "string" },
        "text": { "type": "string" },
        "isApproved": { "type": "boolean" }
      }
    },
    "GlobalSettings": {
      "title": "GlobalSettings",
      "type": "object",
      "properties": {
        "commissionRate": { "type": "number" },
        "payoutThreshold": { "type": "number" },
        "autoApproveVendors": { "type": "boolean" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      { "path": "/users/{userId}", "definition": { "entityName": "User" } },
      { "path": "/users/{userId}/sellerProfiles/{profileId}", "definition": { "entityName": "SellerProfile" } },
      { "path": "/products/{productId}", "definition": { "entityName": "Product" } },
      { "path": "/products/{productId}/reviews/{reviewId}", "definition": { "entityName": "Review" } },
      { "path": "/users/{userId}/orders/{orderId}", "definition": { "entityName": "Order" } },
      { "path": "/newsletterSubscriptions/{id}", "definition": { "entityName": "NewsletterSubscription" } },
      { "path": "/contactMessages/{id}", "definition": { "entityName": "ContactMessage" } },
      { "path": "/roles_admin/{adminId}", "definition": { "entityName": "User" } },
      { "path": "/categories/{id}", "definition": { "entityName": "Category" } },
      { "path": "/testimonials/{id}", "definition": { "entityName": "Testimonial" } },
      { "path": "/settings/global", "definition": { "entityName": "GlobalSettings" } }
    ]
  }
}
