
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PRESCOP SECURITY RULES
     * hybrid security model for a multi-vendor marketplace.
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        (request.auth.token.email != null && request.auth.token.email.lower() == 'admin@prescop.com')
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isResourceOwner(ownerField) {
      return isSignedIn() && resource.data[ownerField] == request.auth.uid;
    }

    function isIncomingOwner(ownerField) {
      return isSignedIn() && request.resource.data[ownerField] == request.auth.uid;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for the admin roles collection.
     */
    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Collection group matches for admin-level queries.
     */
    match /{path=**}/sellerProfiles/{profileId} {
      allow read: if isAdmin();
    }

    match /{path=**}/orders/{orderId} {
      allow read: if isAdmin();
    }

    /**
     * @description User profile management.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId);
      allow delete: if isAdmin();

      match /sellerProfiles/{sellerProfileId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId);
        allow delete: if isAdmin();
      }

      match /orders/{orderId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.customerId == userId;
        allow update, delete: if isAdmin();

        match /orderItems/{orderItemId} {
          allow get, list: if isOwner(userId) || isAdmin();
          allow create: if isOwner(userId);
          allow update, delete: if isAdmin();
        }
      }
    }

    /**
     * @description Marketplace data.
     */
    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /products/{productId} {
      allow get, list: if true;
      allow create: if isIncomingOwner('sellerId') || isAdmin();
      allow update: if (isResourceOwner('sellerId') && request.resource.data.sellerId == resource.data.sellerId) || isAdmin();
      allow delete: if isResourceOwner('sellerId') || isAdmin();

      match /reviews/{reviewId} {
        allow get, list: if true;
        allow create: if isSignedIn();
        allow update: if isResourceOwner('userId') || isAdmin();
        allow delete: if isResourceOwner('userId') || isAdmin();
      }
    }

    match /newsletterSubscriptions/{subscriptionId} {
      allow create: if true;
      allow get, list, update, delete: if isAdmin();
    }

    match /contactMessages/{id} {
      allow create: if true;
      allow get, list, update, delete: if isAdmin();
    }

    match /testimonials/{testimonialId} {
      allow get, list: if resource.data.isApproved == true || isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }
  }
}
